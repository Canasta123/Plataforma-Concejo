---
interface Props {
  numero: string;
  nombre: string;
  icono: string;
  ruta: string;
  tipo: 'estrategico' | 'misional' | 'apoyo' | 'evaluacion';
}

const { numero, nombre, icono, ruta, tipo } = Astro.props;

const colorMap = {
  estrategico: {
    num: 'bg-blue-900 text-white',
    icon: 'text-blue-900',
    iconHover: 'group-hover:text-white',
    border: 'border-blue-100 hover:border-blue-900',
    bg: 'hover:bg-blue-900',
    numHover: 'group-hover:bg-white group-hover:text-blue-900',
    bar: 'bg-blue-900',
  },
  misional: {
    num: 'bg-green-700 text-white',
    icon: 'text-green-700',
    iconHover: 'group-hover:text-white',
    border: 'border-green-100 hover:border-green-700',
    bg: 'hover:bg-green-700',
    numHover: 'group-hover:bg-white group-hover:text-green-700',
    bar: 'bg-green-700',
  },
  apoyo: {
    num: 'bg-yellow-400 text-gray-900',
    icon: 'text-yellow-400',
    iconHover: 'group-hover:text-white',
    border: 'border-yellow-200 hover:border-yellow-400',
    bg: 'hover:bg-yellow-400',
    numHover: 'group-hover:bg-yellow-400 group-hover:text-gray-900',
    bar: 'bg-yellow-400',
  },
  evaluacion: {
    num: 'bg-red-700 text-white',
    icon: 'text-red-700',
    iconHover: 'group-hover:text-white',
    border: 'border-red-100 hover:border-red-700',
    bg: 'hover:bg-red-700',
    numHover: 'group-hover:bg-white group-hover:text-red-700',
    bar: 'bg-red-700',
  },
};

const c = colorMap[tipo];
---

<a
  href={ruta}
  class={`group relative flex items-center gap-3 p-3 rounded-xl border ${c.border} ${c.bg} bg-gray-50/50 hover:text-white transition-all duration-250 cursor-pointer overflow-hidden animate-on-scroll`}
>
  <!-- Left accent bar -->
  <div class={`absolute left-0 top-0 bottom-0 w-0.5 ${c.bar} opacity-40 group-hover:opacity-0 transition-opacity`}></div>

  <!-- Number badge -->
  <span class={`w-7 h-7 rounded-lg ${c.num} ${c.numHover} text-[10px] font-bold flex items-center justify-center shrink-0 transition-colors duration-200 shadow-sm`}>
    {numero}
  </span>

  <!-- Icon -->
  <i class={`${icono} text-lg ${c.icon} ${c.iconHover} transition-colors duration-200 shrink-0 w-5 text-center`}></i>

  <!-- Name -->
  <h3 class="text-xs font-semibold text-gray-700 group-hover:text-white transition-colors duration-200 leading-tight flex-1">
    {nombre}
  </h3>

  <!-- Arrow -->
  <i class="fas fa-chevron-right text-[10px] text-gray-300 group-hover:text-white/70 group-hover:translate-x-0.5 transition-all duration-200 shrink-0"></i>
</a>
