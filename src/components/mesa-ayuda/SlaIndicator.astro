---
interface Props {
  fechaCreacion: string;
  fechaLimite: string;
  estado: string;
}
const { fechaCreacion, fechaLimite, estado } = Astro.props;

const cerrado = estado === 'resuelto' || estado === 'cerrado';
const ahora   = Date.now();
const inicio  = new Date(fechaCreacion).getTime();
const limite  = new Date(fechaLimite).getTime();
const total   = limite - inicio;
const elapsed = ahora - inicio;
const pct     = Math.min(Math.round((elapsed / total) * 100), 100);
const vencido = ahora > limite;

const restanteMs = limite - ahora;
const restanteH  = Math.max(0, Math.floor(restanteMs / 3600000));
const restanteM  = Math.max(0, Math.floor((restanteMs % 3600000) / 60000));

let color   = 'bg-green-500';
let textCls = 'text-green-700';
let label   = `${restanteH}h ${restanteM}m restantes`;

if (cerrado) {
  color   = 'bg-gray-300';
  textCls = 'text-gray-400';
  label   = 'Cerrado';
} else if (vencido) {
  color   = 'bg-red-600';
  textCls = 'text-red-700';
  label   = 'Vencido';
} else if (pct >= 80) {
  color   = 'bg-red-500';
  textCls = 'text-red-700';
} else if (pct >= 50) {
  color   = 'bg-yellow-400';
  textCls = 'text-yellow-700';
}
---
<div class="flex flex-col gap-1 min-w-[120px]">
  <div class="flex justify-between items-center">
    <span class={`text-xs font-semibold ${textCls}`}>{label}</span>
    {!cerrado && <span class="text-[10px] text-gray-400">{pct}%</span>}
  </div>
  <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
    <div class={`h-full rounded-full transition-all ${color}`} style={`width:${cerrado ? 100 : pct}%`}></div>
  </div>
</div>
