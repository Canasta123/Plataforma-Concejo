---
import '../styles/global.css';
import { getSession } from '../lib/auth';
import type { Rol } from '../lib/supabase';
import { supabase } from '../lib/supabase';
import InduccionModal from '../components/mesa-ayuda/interactive/InduccionModal.svelte';
import NotificationsBell from '../components/mesa-ayuda/interactive/NotificationsBell.svelte';

interface Props {
  title:       string;
  description?: string;
  rolRequerido?: Rol;
}

const { title, description = 'Mesa de Ayuda — Concejo Municipal de Chía', rolRequerido } = Astro.props;

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/mesa-ayuda/login');
if (rolRequerido && session.rol !== rolRequerido) return Astro.redirect('/mesa-ayuda');

// Obtener permisos de acceso a evidencias
const { data: dbUser } = await supabase
  .from('usuarios')
  .select('acceso_evidencias')
  .eq('id', session.id)
  .single();
const tieneAccesoEvidencias = dbUser?.acceso_evidencias ?? false;

const navItems: { label: string; href: string; rol: Rol[]; visible?: boolean }[] = [
  { label: 'Usuarios',         href: '/mesa-ayuda/admin',          rol: ['admin'] },
  { label: 'Panel auditoría',  href: '/mesa-ayuda/auditor',        rol: ['admin'] },
  { label: 'Evidencias (Consola)', href: '/mesa-ayuda/evidencias', rol: ['admin', 'auditor', 'solicitante', 'agente'], visible: tieneAccesoEvidencias || ['admin', 'auditor'].includes(session.rol) },
  { label: 'Buzón Evidencias', href: '/mesa-ayuda/buzon-evidencias', rol: ['admin', 'solicitante', 'agente', 'auditor'] },
  { label: 'Reportes Excel',   href: '/mesa-ayuda/reportes',       rol: ['admin', 'auditor'] },
  { label: 'Mis Tickets',      href: '/mesa-ayuda/dashboard',      rol: ['solicitante'] },
  { label: 'Nueva Solicitud',  href: '/mesa-ayuda/nuevo-ticket',   rol: ['solicitante'] },
  { label: 'Tablero',          href: '/mesa-ayuda/agente',         rol: ['agente'] },
  { label: 'Reportes',         href: '/mesa-ayuda/auditor',        rol: ['auditor'] },
  { label: 'Base de Conocimiento', href: '/mesa-ayuda/conocimiento', rol: ['admin', 'solicitante', 'agente', 'auditor'] },
  { label: 'Reservas',         href: '/mesa-ayuda/reservas',       rol: ['admin', 'solicitante', 'agente', 'auditor'] },
];

const itemsVisibles = navItems.filter(i => {
  const matchRol = i.rol.includes(session.rol);
  const matchVisible = i.visible !== undefined ? i.visible : true;
  return matchRol && matchVisible;
});
const rutaActual = Astro.url.pathname;

const { data: configRows } = await supabase
  .from('config_global')
  .select('clave, valor')
  .in('clave', ['banner_activo', 'banner_mensaje', 'banner_tipo']);

const config: Record<string, string> = {};
for (const row of configRows ?? []) config[row.clave] = row.valor;

// Validar inducción pendiente
let mostrarInduccionModal = false;
if (session && session.rol !== 'admin') {
  const { data: dbUser } = await supabase
    .from('usuarios')
    .select('induccion_completada, induccion_habilitada')
    .eq('id', session.id)
    .single();

  if (dbUser && dbUser.induccion_habilitada && !dbUser.induccion_completada) {
    mostrarInduccionModal = true;
  }
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Mesa de Ayuda — Concejo de Chía</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col" style="font-family: 'Lato', sans-serif;">

    <!-- Header -->
    <header class="bg-white border-b border-gray-200 shadow-sm shrink-0 z-30">
      <div class="flex items-center justify-between px-6 md:px-10 h-16">

        <!-- Logo + título -->
        <div class="flex items-center gap-4">
          <a href="/mesa-ayuda" class="flex items-center gap-3 group">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background-color: var(--color-brand-blue);">
              <i class="fas fa-headset text-white text-sm"></i>
            </div>
            <div class="hidden sm:block">
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest leading-none">Concejo de Chía</p>
              <p class="text-sm font-bold leading-tight" style="color: var(--color-brand-blue); font-family: 'Montserrat', sans-serif;">
                Mesa de Ayuda
              </p>
            </div>
          </a>

          <!-- Nav -->
          <nav class="hidden md:flex items-center gap-1 ml-6">
            {itemsVisibles.map(item => (
              <a
                href={item.href}
                class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
                  rutaActual.startsWith(item.href)
                    ? 'bg-blue-50 text-brand-blue font-semibold'
                    : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'
                }`}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>

        <!-- Usuario + cerrar sesión -->
        <div class="flex items-center gap-3">
          <NotificationsBell client:load />

          <div class="hidden sm:flex flex-col items-end">
            <span class="text-sm font-semibold text-gray-800">{session.nombre}</span>
            <span class="text-xs text-gray-400 capitalize">{session.rol} · {session.cargo}</span>
          </div>
          <div class="w-9 h-9 rounded-full bg-gray-100 flex items-center justify-center text-gray-600 font-bold text-sm shrink-0">
            {session.nombre.charAt(0).toUpperCase()}
          </div>
          <form action="/api/mesa-ayuda/auth/logout" method="POST">
            <button
              type="submit"
              title="Cerrar sesión"
              class="w-9 h-9 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 flex items-center justify-center transition-colors"
            >
              <i class="fas fa-sign-out-alt text-sm"></i>
            </button>
          </form>
        </div>
      </div>

      <!-- Nav móvil -->
      <nav class="md:hidden flex items-center gap-1 px-4 pb-2 overflow-x-auto">
        {itemsVisibles.map(item => (
          <a
            href={item.href}
            class={`px-3 py-1.5 rounded-lg text-xs font-medium whitespace-nowrap transition-colors ${
              rutaActual.startsWith(item.href)
                ? 'bg-blue-50 text-brand-blue font-semibold'
                : 'text-gray-600 hover:bg-gray-100'
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </header>

    <!-- Banner global -->
    {config.banner_activo === 'true' && config.banner_mensaje && (
      <div class={`px-6 py-3 text-sm font-medium flex gap-3 items-start justify-center ${
        config.banner_tipo === 'info' ? 'bg-blue-600 text-white' :
        config.banner_tipo === 'warning' ? 'bg-[#FFD402] text-gray-900' :
        config.banner_tipo === 'danger' ? 'bg-red-600 text-white' :
        'bg-green-600 text-white'
      }`}>
        <i class={`fas mt-1 shrink-0 ${
          config.banner_tipo === 'info' ? 'fa-info-circle' :
          config.banner_tipo === 'warning' ? 'fa-exclamation-triangle' :
          config.banner_tipo === 'danger' ? 'fa-times-circle' : 'fa-check-circle'
        }`}></i>
        <span>{config.banner_mensaje}</span>
      </div>
    )}

    <!-- Contenido -->
    <main class="flex-1 p-6 md:p-8 max-w-7xl w-full mx-auto">
      <slot />
    </main>

    <!-- Footer mínimo -->
    <footer class="border-t border-gray-200 bg-white py-3 px-6 shrink-0">
      <p class="text-xs text-gray-400 text-center">
        Mesa de Ayuda — Concejo Municipal de Chía &nbsp;·&nbsp; SGC 2026
      </p>
    </footer>

    <!-- Modal de Inducción -->
    {mostrarInduccionModal && <InduccionModal client:load userId={session.id} userNombre={session.nombre} />}
  </body>
</html>
