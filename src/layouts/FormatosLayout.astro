---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProcessNav from '../components/navigation/ProcessNav.astro';

interface Props {
  title: string;
  description?: string;
  numero: string;
  tituloHeader: string;
  subtituloHeader?: string;
  tipo: 'estrategico' | 'misional' | 'apoyo' | 'evaluacion';
  badge?: string;
  badgeIcon?: string;
  footerTexto?: string;
  rutaActual: string;
}

const {
  title,
  description,
  numero,
  tituloHeader,
  subtituloHeader,
  tipo,
  badge,
  badgeIcon = 'fas fa-file-alt',
  footerTexto = 'Gestión Documental del Proceso',
  rutaActual,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="slide-container h-screen flex flex-col overflow-hidden">
    <Header
      titulo={tituloHeader}
      subtitulo={subtituloHeader}
      numero={numero}
      tipo={tipo}
      badge={badge}
      badgeIcon={badgeIcon}
    />

    <main class="flex-1 min-h-0 p-5 md:p-6 overflow-y-auto">
      <div class="min-h-full w-full">
        <slot />
      </div>
    </main>

    <Footer textoIzquierdo={footerTexto} iconoIzquierdo="fas fa-folder-open" />
    <ProcessNav rutaActual={rutaActual} />
  </div>
</BaseLayout>

<!-- El script del explorador de archivos se carga en las páginas individuales -->
