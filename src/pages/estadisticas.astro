---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProcessNav from '../components/navigation/ProcessNav.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Estadísticas del SGC" description="Resumen Visual de Formatos">
  <div class="slide-container h-screen overflow-hidden">
    <Header
      titulo="Distribución de Formatos por Proceso"
      subtitulo="Sistema de Gestión de Calidad"
      numero=""
      tipo="evaluacion"
      badge="Consolidado 2026"
      badgeIcon="fas fa-database"
    />

    <main class="flex-1 min-h-0 p-8 flex flex-col lg:flex-row gap-8 overflow-y-auto custom-scroll">
      <!-- Left Column: Key Stats -->
      <div class="w-full lg:w-1/3 flex flex-col gap-6">
        
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-1 gap-6">
          <!-- Stat 1 -->
          <div class="bg-white rounded-xl p-5 card-shadow border-l-4 border-brand-blue flex items-center justify-between animate-on-scroll hover-lift">
            <div>
              <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1">Total Procesos</p>
              <h3 class="text-3xl font-bold text-brand-blue stat-animate">9</h3>
            </div>
            <div class="h-12 w-12 rounded-xl bg-blue-50 flex items-center justify-center text-brand-blue text-xl">
              <i class="fas fa-cogs"></i>
            </div>
          </div>
          
          <!-- Stat 2 -->
          <div class="bg-white rounded-xl p-5 card-shadow border-l-4 border-brand-gold flex items-center justify-between animate-on-scroll hover-lift" style="animation-delay: 0.1s;">
            <div>
              <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1">Total Formatos</p>
              <h3 class="text-3xl font-bold text-brand-gold stat-animate">~125</h3>
            </div>
            <div class="h-12 w-12 rounded-xl bg-yellow-50 flex items-center justify-center text-brand-gold text-xl">
              <i class="fas fa-file-alt"></i>
            </div>
          </div>
          
          <!-- Stat 3 -->
          <div class="bg-white rounded-xl p-5 card-shadow border-l-4 border-green-500 flex items-center justify-between animate-on-scroll hover-lift" style="animation-delay: 0.2s;">
            <div>
              <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1">Mayor Volumen</p>
              <h3 class="text-sm font-bold text-gray-800 leading-tight">Gestión Admin.</h3>
            </div>
            <div class="h-12 w-12 rounded-xl bg-green-50 flex items-center justify-center text-green-600 text-xl shrink-0">
              <i class="fas fa-chart-bar"></i>
            </div>
          </div>
        </div>
        
        <!-- Legend -->
        <div class="bg-white rounded-xl p-6 card-shadow mt-auto animate-on-scroll flex-1" style="animation-delay: 0.3s;">
          <h4 class="text-sm font-bold text-gray-700 uppercase mb-4 border-b border-gray-100 pb-2">Categorías</h4>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full bg-[#3359A4] shadow-sm"></div>
              <p class="text-sm text-gray-600 font-medium">Procesos Estratégicos</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full bg-[#009741] shadow-sm"></div>
              <p class="text-sm text-gray-600 font-medium">Procesos Misionales</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full bg-[#EBAA00] shadow-sm"></div>
              <p class="text-sm text-gray-600 font-medium">Procesos de Apoyo</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full bg-[#E30D21] shadow-sm"></div>
              <p class="text-sm text-gray-600 font-medium">Evaluación Independiente</p>
            </div>
          </div>
        </div>
        
      </div>

      <!-- Right Column: Chart -->
      <div class="w-full lg:w-2/3 bg-white rounded-xl card-shadow p-6 flex flex-col relative animate-on-scroll" style="animation-delay: 0.2s;">
        <div class="absolute top-6 right-6 z-10 hidden md:block">
          <span class="bg-blue-50 text-brand-blue text-[10px] font-bold px-3 py-1.5 rounded-md border border-blue-100">
            Datos aproximados
          </span>
        </div>
        <h3 class="text-xl font-bold text-brand-blue mb-2">Volumen Documental por Proceso</h3>
        <p class="text-sm text-gray-500 mb-6">Cantidad estimada de formatos y registros del SGC.</p>
        <div class="flex-1 relative w-full min-h-[400px]">
          <canvas id="formatChart"></canvas>
        </div>
      </div>
    </main>

    <footer class="h-12 bg-white border-t border-gray-200 flex items-center justify-between px-12 text-xs text-gray-400 shrink-0">
      <div class="flex items-center space-x-2">
        <i class="fas fa-chart-pie text-brand-blue"></i>
        <p>Indicadores de Gestión Documental</p>
      </div>
      <p>Concejo Municipal de Chía - 2026</p>
    </footer>

    <ProcessNav rutaActual="/estadisticas" />
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const ctx = document.getElementById('formatChart');
      if (!ctx) return;
      
      if (ctx.__chartInstance) {
        ctx.__chartInstance.destroy();
      }
      
      ctx.__chartInstance = new Chart(ctx, {
          type: 'bar',
          data: {
            labels: [
              'Dir. Estratégico',
              'Gestión Calidad',
              'Atención Ciudadano',
              'Control Político',
              'Proyectos Acuerdo',
              'Gestión Jurídica',
              'Gestión TI',
              'Gestión Admin.',
              'Evaluación Indep.'
            ],
            datasets: [{
              label: 'Cantidad de Formatos',
              data: [12, 18, 5, 10, 8, 15, 20, 32, 5],
              backgroundColor: [
                '#3359A4', '#3359A4', '#3359A4', 
                '#009741', '#009741', 
                '#EBAA00', '#EBAA00', '#EBAA00', 
                '#E30D21'
              ],
              borderWidth: 0,
              borderRadius: 6
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                display: false
              },
              tooltip: {
                backgroundColor: 'rgba(255, 255, 255, 0.9)',
                titleColor: '#1e3a8a',
                bodyColor: '#475569',
                borderColor: '#e2e8f0',
                borderWidth: 1,
                padding: 10,
                boxPadding: 4
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: {
                  color: '#f1f5f9',
                  drawBorder: false
                }
              },
              x: {
                grid: {
                  display: false
                },
                ticks: {
                  maxRotation: 45,
                  minRotation: 45,
                  font: {
                    size: 11
                  }
                }
              }
            }
          }
        });
    });
  </script>
</BaseLayout>

<style>
  .custom-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scroll::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  .custom-scroll::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>
