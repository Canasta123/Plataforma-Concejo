---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
import DownloadButton from '../../components/DownloadButton.astro';
---

<ProcesoLayout
  title="Proyectos de Acuerdo - Misionales"
  numero="05"
  tituloHeader="Proyectos de Acuerdo"
  subtituloHeader="Caracterización del Proceso"
  tipo="misional"
  badge="Macroproceso"
  badgeIcon="fas fa-file-signature"
  rutaActual="/misionales/proyectos-acuerdo"
>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    <!-- Left Column: Meta Information (4/12) -->
    <div class="lg:col-span-4 flex flex-col gap-6">
      
      <!-- Process Type Card -->
      <div class="bg-white rounded-xl p-6 card-shadow border-l-8 category-missional relative overflow-hidden group animate-on-scroll">
        <div class="absolute right-0 top-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
          <i class="fas fa-scroll text-8xl text-green-700"></i>
        </div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center text-green-700">
              <i class="fas fa-layer-group"></i>
            </div>
            <h3 class="text-gray-500 font-bold text-xs uppercase tracking-wider">Tipo de Proceso</h3>
          </div>
          <p class="text-2xl font-bold text-green-700">Misional</p>
          <div class="mt-4 text-sm text-gray-600 leading-snug">
            Procesos que contribuyen directamente al cumplimiento de la misión institucional y generan el servicio para la comunidad.
          </div>
        </div>
      </div>

      <!-- Responsible / Encargados Card -->
      <div class="bg-white rounded-xl p-6 card-shadow border-l-8 border-gray-300 flex-1 relative overflow-hidden flex flex-col animate-on-scroll" style="animation-delay: 0.1s;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-600">
            <i class="fas fa-user-tie"></i>
          </div>
          <h3 class="text-gray-500 font-bold text-xs uppercase tracking-wider">Responsables / Encargados</h3>
        </div>
        <div class="space-y-4 flex-1">
          <div class="flex items-start gap-3 p-4 rounded-lg bg-gray-50 border border-gray-100">
            <div class="mt-1 text-brand-gold"><i class="fas fa-gavel"></i></div>
            <div>
              <p class="font-bold text-gray-800 text-base">Presidente</p>
              <p class="text-xs text-gray-500 uppercase tracking-wide">Mesa Directiva</p>
            </div>
          </div>
        </div>
        <!-- Additional info regarding context -->
        <div class="mt-auto pt-4 border-t border-gray-100">
          <p class="text-xs text-gray-400 italic">
            Responsable de la gestión directiva de las iniciativas normativas.
          </p>
        </div>
      </div>
      
    </div>

    <!-- Right Column: Core Information (8/12) -->
    <div class="lg:col-span-8 flex flex-col gap-6">
      
      <!-- Objective Section -->
      <div class="bg-white rounded-xl p-6 card-shadow relative animate-on-scroll">
        <div class="absolute -top-3 left-8 bg-brand-gold text-white px-4 py-1 rounded shadow-sm text-xs font-bold uppercase tracking-widest border border-black z-10">
          <i class="fas fa-bullseye mr-2"></i>Objetivo del Proceso
        </div>
        <div class="mt-3 flex flex-col md:flex-row gap-6 items-start">
          <div class="flex-1">
            <p class="text-base text-gray-700 leading-relaxed font-medium text-justify">
              Gestionar las iniciativas presentadas por las diferentes instancias permitidas por la ley (proyectos de acuerdo) con el fin de establecer políticas públicas que busquen el beneficio de la comunidad del Municipio.
            </p>
          </div>
          <div class="hidden md:flex w-1/6 justify-center items-center opacity-80">
            <i class="fas fa-file-contract text-5xl text-gray-200"></i>
          </div>
        </div>
      </div>

      <!-- Main Procedure Highlight (New Section) -->
      <div class="bg-white rounded-xl p-5 card-shadow border-l-4 border-brand-blue flex items-center justify-between animate-on-scroll" style="animation-delay: 0.1s;">
        <div>
          <h4 class="text-xs font-bold text-brand-blue uppercase tracking-widest mb-1">Procedimiento Principal</h4>
          <h3 class="text-lg font-bold text-gray-800">Trámite de Proyectos de Acuerdo</h3>
          <p class="text-sm text-gray-500 mt-1">Aplicable a proyectos radicados en la Secretaría General.</p>
        </div>
        <a href="/C-Procedimientos/Formato Procedimiento Tramite de Proyectos de Acuerdo.pdf" download target="_blank" class="w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-folder-open text-xl group-hover:hidden"></i>
          <i class="fas fa-download text-xl hidden group-hover:block"></i>
        </a>
      </div>

      <!-- Scope / Alcance Section -->
      <div class="bg-white rounded-xl p-6 card-shadow flex-1 relative animate-on-scroll" style="animation-delay: 0.2s;">
        <div class="absolute -top-3 left-8 bg-green-700 text-white px-4 py-1 rounded shadow-sm text-xs font-bold uppercase tracking-widest border border-black z-10">
          <i class="fas fa-map-signs mr-2"></i>Alcance
        </div>
        <div class="mt-4 relative h-full flex flex-col justify-center py-4">
          <!-- Start Point -->
          <div class="relative pl-8 pb-8 border-l-2 border-green-300 ml-4">
            <div class="absolute w-4 h-4 rounded-full bg-green-500 border-4 border-white shadow -left-[9px] top-0"></div>
            <h4 class="text-sm font-bold text-green-700 uppercase mb-2 mt-[-4px]">Inicio</h4>
            <div class="text-gray-600 bg-green-50 p-4 rounded-lg border border-green-100 text-sm shadow-sm">
              <p>Inicia con la <span class="font-bold text-gray-800">radicación de los proyectos de acuerdo municipal</span> ante la Secretaría General.</p>
            </div>
          </div>
          <!-- End Point -->
          <div class="relative pl-8 ml-4">
            <div class="absolute w-4 h-4 rounded-full bg-red-500 border-4 border-white shadow -left-[9px] top-0"></div>
            <h4 class="text-sm font-bold text-red-700 uppercase mb-2 mt-[-4px]">Fin</h4>
            <div class="text-gray-600 bg-red-50 p-4 rounded-lg border border-red-100 text-sm shadow-sm">
              <p>Finaliza con la <span class="font-bold text-gray-800">verificación de la implementación</span> del acuerdo municipal sancionado.</p>
            </div>
          </div>
          
          <!-- Connector visual -->
          <div class="absolute right-8 top-1/2 transform -translate-y-1/2 opacity-10 hidden lg:block">
            <i class="fas fa-tasks text-8xl text-green-700"></i>
          </div>
        </div>
      </div>
      
    </div>
  </div>
  
  <div class="mt-6 flex justify-end">
    <DownloadButton href="/C-Procesos/TPA.pdf" tipo="misional" texto="Descargar Caracterización" />
  </div>
</ProcesoLayout>
