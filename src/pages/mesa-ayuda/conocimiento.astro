---
import '../../styles/global.css';
import KnowledgeSearch from '../../components/mesa-ayuda/interactive/KnowledgeSearch.svelte';
import { getSession } from '../../lib/auth';
import { supabase } from '../../lib/supabase';

const session = await getSession(Astro.cookies);

const { data: articlesFromDb } = await supabase
  .from('kb_articulos')
  .select('*')
  .order('created_at', { ascending: false });

const articuloSlaCategorias = {
  id: 'sla-categorias-help',
  titulo: 'Guía de Categorías y Tiempos de Respuesta (SLA)',
  categoria: 'otro',
  tags: ['SLA', 'Categorías', 'Hardware', 'Software', 'Redes', 'Horario', 'Tiempos'],
  resumen: 'Aprende a clasificar correctamente tu solicitud de soporte y conoce los horarios hábiles y límites de respuesta.',
  contenido: `Para garantizar una atención oportuna en la Mesa de Ayuda del Concejo Municipal de Chía, es indispensable clasificar correctamente tu solicitud al momento de crear un ticket.

**1. HARDWARE (Dispositivos Físicos)**
Cualquier falla o requerimiento de equipos físicos.
• Ejemplos: Computadores que no encienden, fallas en pantallas, ratón o teclado dañado, problemas con impresoras físicas o escaners.

**2. SOFTWARE (Programas y Aplicativos)**
Cualquier incidente relacionado con el sistema operativo, programas instalados o accesos de usuario.
• Ejemplos: El computador está lento, problemas con Microsoft Office (Word, Excel), errores al configurar el correo institucional o fallas en los aplicativos internos del Concejo.

**3. REDES Y CONECTIVIDAD**
Relacionado con la conexión a la infraestructura digital del Concejo.
• Ejemplos: Pérdida de conexión a internet o Wi-Fi, fallas en la telefonía física, problemas para acceder a la carpeta compartida en la red local (NAS).

**4. OTROS / GENERAL**
Cualquier solicitud de soporte técnico que no encaje en las descripciones anteriores.

---

### Horario Hábil y Límites de Respuesta (SLA)
Los plazos máximos para resolver tu solicitud se calculan **únicamente con base a las horas hábiles del Concejo de Chía**:
• **Horario de atención:** Lunes a Viernes de **8:00 AM a 5:30 PM**.
• **Hora de Almuerzo:** El tiempo se congela de **1:00 PM a 2:00 PM** (no laboral).
• **Fines de semana:** Sábados y domingos el tiempo se detiene y se reanuda el lunes a las 8:00 AM.

*Ejemplo:* Si radicas un ticket con SLA de 4 horas a las 5:00 PM de un lunes, consumirá 30 minutos ese día y las 3 horas y 30 minutos restantes empezarán a contar el martes a las 8:00 AM, teniendo como fecha límite el martes a las 11:30 AM.`
};

const articles = articlesFromDb 
  ? [articuloSlaCategorias, ...articlesFromDb] 
  : [articuloSlaCategorias];

const panelHref = session
  ? (session.rol === 'agente' ? '/mesa-ayuda/agente' : session.rol === 'auditor' ? '/mesa-ayuda/auditor' : '/mesa-ayuda/dashboard')
  : null;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Base de Conocimiento | Mesa de Ayuda — Concejo de Chía</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Lato', sans-serif;
      background: #f3f4f6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      color: #111;
    }

    /* ── Header ── */
    .top-bar {
      background: #1e3a8a;
      padding: 0 1.5rem;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
      z-index: 30;
    }
    .top-bar-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }
    .top-bar-icon {
      width: 36px; height: 36px;
      background: rgba(255,255,255,0.15);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: white;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .top-bar-text p:first-child {
      font-size: 0.65rem;
      font-weight: 700;
      color: rgba(255,255,255,0.55);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      line-height: 1;
      margin: 0;
    }
    .top-bar-text p:last-child {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.9rem;
      font-weight: 700;
      color: white;
      line-height: 1.2;
      margin: 0;
    }
    .top-bar-actions { display: flex; align-items: center; gap: 0.75rem; }
    .btn-login {
      background: #FFD402;
      color: #111;
      font-weight: 700;
      font-size: 0.8rem;
      font-family: 'Montserrat', sans-serif;
      padding: 0.45rem 1rem;
      border-radius: 6px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: background 0.2s;
      border: none;
      cursor: pointer;
    }
    .btn-login:hover { background: #efc200; }
    .btn-panel {
      font-size: 0.8rem;
      font-weight: 600;
      color: rgba(255,255,255,0.8);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: color 0.2s;
    }
    .btn-panel:hover { color: white; }

    /* ── Hero ── */
    .hero {
      background: linear-gradient(135deg, #1e3a8a 0%, #3359a4 60%, #0384ba 100%);
      padding: 3rem 1.5rem 3.5rem;
      text-align: center;
      color: white;
    }
    .hero-icon {
      width: 64px; height: 64px;
      background: rgba(255,255,255,0.15);
      border: 2px solid rgba(255,255,255,0.25);
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      color: #FFD402;
      margin-bottom: 1rem;
    }
    .hero h1 {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.6rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
    }
    .hero p {
      font-size: 0.9rem;
      color: rgba(255,255,255,0.75);
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.6;
    }

    /* ── Content ── */
    .content {
      flex: 1;
      max-width: 900px;
      width: 100%;
      margin: 0 auto;
      padding: 2.5rem 1.5rem;
    }

    /* ── Footer ── */
    footer {
      background: white;
      border-top: 1px solid #e5e7eb;
      padding: 0.75rem 1.5rem;
      text-align: center;
      font-size: 0.72rem;
      color: #9ca3af;
      flex-shrink: 0;
    }

    /* ── Tailwind esenciales para KnowledgeSearch ── */
    mark { background: #fef08a; border-radius: 2px; padding: 0 2px; }
  </style>
</head>
<body>

  <!-- Barra superior -->
  <header class="top-bar">
    <a href="/mesa-ayuda/login" class="top-bar-brand">
      <div class="top-bar-icon"><i class="fas fa-headset"></i></div>
      <div class="top-bar-text">
        <p>Concejo de Chía</p>
        <p>Mesa de Ayuda</p>
      </div>
    </a>
    <div class="top-bar-actions">
      {panelHref ? (
        <a href={panelHref} class="btn-panel">
          <i class="fas fa-arrow-left" style="font-size:0.7rem;"></i> Mi panel
        </a>
      ) : (
        <a href="/mesa-ayuda/login" class="btn-login">
          <i class="fas fa-sign-in-alt"></i> Iniciar sesión
        </a>
      )}
    </div>
  </header>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-icon"><i class="fas fa-book-open"></i></div>
    <h1>Base de Conocimiento</h1>
    <p>Encuentra soluciones rápidas a los problemas más frecuentes antes de radicar un ticket.</p>
  </div>

  <!-- Buscador + artículos -->
  <main class="content">
    <KnowledgeSearch client:load articles={articles ?? []} />
  </main>

  <footer>
    Mesa de Ayuda &nbsp;·&nbsp; Concejo Municipal de Chía &nbsp;·&nbsp; SGC 2026
  </footer>

</body>
</html>
