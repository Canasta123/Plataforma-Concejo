---
import MesaAyudaLayout from '../../../layouts/MesaAyudaLayout.astro';
import ExportExcelModal from '../../../components/mesa-ayuda/interactive/ExportExcelModal.svelte';
import { getSession } from '../../../lib/auth';
import { supabase } from '../../../lib/supabase';

const session = await getSession(Astro.cookies);
if (!session || !['auditor', 'admin'].includes(session.rol)) {
  return Astro.redirect('/mesa-ayuda');
}

const [{ data: agentes }, { data: exportaciones }] = await Promise.all([
  supabase
    .from('usuarios')
    .select('id, nombre')
    .eq('rol', 'agente')
    .eq('activo', true)
    .order('nombre'),
  supabase
    .from('exportaciones')
    .select('*, usuario:usuario_id ( nombre, correo )')
    .order('created_at', { ascending: false })
    .limit(50),
]);
---

<MesaAyudaLayout title="Reportes Excel" rolRequerido={session.rol as any}>
  <div class="mb-6">
    <h1 class="text-xl font-bold text-gray-900" style="font-family:'Montserrat',sans-serif;">
      Reportes Excel
    </h1>
    <p class="text-sm text-gray-500 mt-1">
      Exporta tickets con filtros personalizados. Puedes guardar plantillas de filtros para reutilizarlas.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Panel de exportación -->
    <div>
      <ExportExcelModal
        client:load
        rol={session.rol}
        agentes={agentes ?? []}
      />
    </div>

    <!-- Historial de exportaciones -->
    <div>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
          <i class="fas fa-history text-gray-400 text-sm"></i>
          <h2 class="text-sm font-bold text-gray-800">Historial de exportaciones</h2>
        </div>

        {exportaciones && exportaciones.length > 0 ? (
          <div class="divide-y divide-gray-50">
            {exportaciones.map((e: any) => (
              <div class="px-5 py-3 hover:bg-gray-50 transition-colors">
                <div class="flex items-start justify-between gap-2">
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-semibold text-gray-800">
                      {e.usuario?.nombre ?? 'Usuario desconocido'}
                    </p>
                    <p class="text-[10px] text-gray-400">
                      {new Date(e.created_at).toLocaleString('es-CO', { timeZone: 'America/Bogota', dateStyle: 'medium', timeStyle: 'short' })}
                    </p>
                  </div>
                  <div class="text-right shrink-0">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-blue-100 text-blue-700">
                      {e.tickets_count} tickets
                    </span>
                    {e.incluyo_internos && (
                      <p class="text-[9px] text-orange-500 mt-0.5">inc. notas internas</p>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="py-12 text-center text-gray-400">
            <i class="fas fa-file-excel text-3xl text-gray-200 mb-3 block"></i>
            <p class="text-sm">Aún no hay exportaciones registradas.</p>
          </div>
        )}
      </div>
    </div>
  </div>
</MesaAyudaLayout>
