---
import { getSession } from '../../lib/auth';

const session = await getSession(Astro.cookies);
if (session) return Astro.redirect('/mesa-ayuda', 302);

const error = Astro.url.searchParams.get('error');
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión | Mesa de Ayuda — Concejo de Chía</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Lato', sans-serif;
        min-height: 100vh;
        background: linear-gradient(135deg, #1e3a8a 0%, #3359A4 50%, #0384BA 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
      }
      .card {
        background: white;
        border-radius: 1.25rem;
        box-shadow: 0 25px 60px rgba(0,0,0,0.25);
        width: 100%;
        max-width: 420px;
        overflow: hidden;
      }
      .card-header {
        background: #1e3a8a;
        padding: 2rem;
        text-align: center;
        color: white;
      }
      .logo-ring {
        width: 72px; height: 72px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
        border: 2px solid rgba(255,255,255,0.3);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1rem;
      }
      .card-header h1 {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      .card-header p {
        font-size: 0.8rem;
        opacity: 0.75;
        margin-top: 0.25rem;
      }
      .card-body { padding: 2rem; }
      .alert-error {
        background: #fee2e2;
        border: 1px solid #fca5a5;
        border-radius: 0.6rem;
        padding: 0.75rem 1rem;
        color: #b91c1c;
        font-size: 0.85rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .field { margin-bottom: 1.25rem; }
      label {
        display: block;
        font-size: 0.78rem;
        font-weight: 700;
        color: #374151;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.4rem;
      }
      .input-wrap { position: relative; }
      .input-icon {
        position: absolute;
        left: 0.9rem;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 0.9rem;
        pointer-events: none;
      }
      input[type="email"],
      input[type="password"] {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        border: 1.5px solid #d1d5db;
        border-radius: 0.6rem;
        font-size: 0.95rem;
        font-family: 'Lato', sans-serif;
        color: #111827;
        background: #f9fafb;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
      }
      input:focus {
        border-color: #3359A4;
        background: white;
        box-shadow: 0 0 0 3px rgba(51,89,164,0.12);
      }
      .btn-submit {
        width: 100%;
        padding: 0.85rem;
        background: #FFD402;
        color: #111827;
        border: none;
        border-radius: 0.6rem;
        font-size: 0.95rem;
        font-weight: 700;
        font-family: 'Montserrat', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
        margin-top: 0.5rem;
      }
      .btn-submit:hover {
        background: #efc200;
        box-shadow: 0 4px 14px rgba(255,212,2,0.4);
        transform: translateY(-1px);
      }
      .btn-submit:active { transform: translateY(0); }
      .divider {
        text-align: center;
        margin: 1.5rem 0 1rem;
        color: #9ca3af;
        font-size: 0.8rem;
      }
      .kb-link {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        color: #3359A4;
        text-decoration: none;
        font-weight: 600;
        padding: 0.5rem;
        border-radius: 0.4rem;
        transition: background 0.2s;
      }
      .kb-link:hover { background: #eff6ff; }
      .footer-note {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.72rem;
        color: rgba(255,255,255,0.55);
      }
    </style>
  </head>
  <body>

    <div class="card">
      <div class="card-header">
        <div class="logo-ring">
          <i class="fas fa-headset" style="font-size:1.8rem;"></i>
        </div>
        <h1>Mesa de Ayuda</h1>
        <p>Concejo Municipal de Chía</p>
      </div>

      <div class="card-body">
        {error && (
          <div class="alert-error">
            <i class="fas fa-exclamation-circle"></i>
            {error === 'credenciales' ? 'Correo o contraseña incorrectos.' : 'Ocurrió un error. Intenta de nuevo.'}
          </div>
        )}

        <form id="loginForm" method="POST" action="/api/mesa-ayuda/auth/login">
          <div class="field">
            <label for="correo">Correo institucional</label>
            <div class="input-wrap">
              <i class="fas fa-envelope input-icon"></i>
              <input
                type="email"
                id="correo"
                name="correo"
                placeholder="usuario@concejo.gov.co"
                required
                autocomplete="email"
              />
            </div>
          </div>

          <div class="field">
            <label for="password">Contraseña</label>
            <div class="input-wrap">
              <i class="fas fa-lock input-icon"></i>
              <input
                type="password"
                id="password"
                name="password"
                placeholder="••••••••"
                required
                autocomplete="current-password"
              />
            </div>
          </div>

          <button type="submit" class="btn-submit">
            <i class="fas fa-sign-in-alt"></i>
            Ingresar
          </button>
        </form>

        <div class="divider">Opciones adicionales</div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <a href="/mesa-ayuda/conocimiento" class="kb-link">
            <i class="fas fa-book-open"></i>
            Base de Conocimiento
          </a>
          <a href="/" class="kb-link" style="color: #4b5563;">
            <i class="fas fa-home"></i>
            Volver al SGC
          </a>
        </div>
      </div>
    </div>

    <p class="footer-note">SGC 2026 · Acceso restringido a funcionarios autorizados</p>

    <script>
      const form = document.getElementById('loginForm');
      const btn  = form?.querySelector('button[type="submit"]');
      form?.addEventListener('submit', () => {
        if (btn) {
          btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Verificando...';
          (btn as HTMLButtonElement).disabled = true;
        }
      });
    </script>

  </body>
</html>
