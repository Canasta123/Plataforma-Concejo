---
import MesaAyudaLayout from '../../layouts/MesaAyudaLayout.astro';
import StatusBadge from '../../components/mesa-ayuda/StatusBadge.astro';
import ExportExcelModal from '../../components/mesa-ayuda/interactive/ExportExcelModal.svelte';
import { getSession } from '../../lib/auth';
import { supabase } from '../../lib/supabase';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/mesa-ayuda/login');
if (session.rol !== 'solicitante') return Astro.redirect('/mesa-ayuda');

const { data: tickets } = await supabase
  .from('tickets')
  .select('*')
  .eq('creador_id', session.id)
  .order('fecha_creacion', { ascending: false });

const abiertos   = (tickets ?? []).filter(t => t.estado === 'abierto').length;
const enProgreso = (tickets ?? []).filter(t => t.estado === 'en_progreso').length;
const resueltos  = (tickets ?? []).filter(t => t.estado === 'resuelto' || t.estado === 'cerrado').length;
---
<MesaAyudaLayout title="Mi Dashboard" session={session}>
  <div class="max-w-4xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Mis Solicitudes</h1>
        <p class="text-sm text-gray-500 mt-0.5">Hola, {session.nombre}</p>
      </div>
      <div class="flex items-center gap-2">
        <button
          id="btnExportSol"
          onclick="document.getElementById('exportModalSol').classList.toggle('hidden')"
          class="flex items-center gap-2 px-4 py-2.5 rounded-xl font-bold text-sm text-gray-700 border border-gray-200 hover:border-gray-300 bg-white transition-all"
        >
          <i class="fas fa-file-excel text-green-600"></i> Exportar
        </button>
        <a
          href="/mesa-ayuda/nuevo-ticket"
          class="flex items-center gap-2 px-5 py-2.5 rounded-xl font-bold text-sm text-gray-900 hover:opacity-90 transition-opacity shadow-sm"
          style="background-color:#FFD402;"
        >
          <i class="fas fa-plus"></i> Nueva Solicitud
        </a>
      </div>
    </div>

    <!-- Export modal -->
    <div id="exportModalSol" class="hidden mt-6">
      <ExportExcelModal client:load rol="solicitante" agentes={[]} />
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-4 mb-8">
      {[
        { label: 'Abiertos',    count: abiertos,   icon: 'fa-folder-open', cls: 'text-blue-600',   bg: 'bg-blue-50' },
        { label: 'En Progreso', count: enProgreso,  icon: 'fa-spinner',     cls: 'text-yellow-600', bg: 'bg-yellow-50' },
        { label: 'Resueltos',   count: resueltos,   icon: 'fa-check-circle', cls: 'text-green-600', bg: 'bg-green-50' },
      ].map(s => (
        <div class={`rounded-xl p-4 ${s.bg} border border-gray-100`}>
          <div class="flex items-center gap-2 mb-1">
            <i class={`fas ${s.icon} ${s.cls} text-sm`}></i>
            <span class="text-xs font-semibold text-gray-500">{s.label}</span>
          </div>
          <p class={`text-2xl font-bold ${s.cls}`}>{s.count}</p>
        </div>
      ))}
    </div>

    <!-- Ticket list -->
    {(tickets ?? []).length === 0 ? (
      <div class="flex flex-col items-center justify-center py-20 text-gray-300">
        <i class="fas fa-inbox text-5xl mb-4"></i>
        <p class="text-base font-medium text-gray-400">No tienes solicitudes aún</p>
        <a href="/mesa-ayuda/nuevo-ticket" class="mt-4 text-sm text-blue-500 hover:underline">Crear tu primera solicitud</a>
      </div>
    ) : (
      <div class="flex flex-col gap-3">
        {(tickets ?? []).map(t => (
          <a
            href={`/mesa-ayuda/ticket/${t.id}`}
            class="block bg-white rounded-xl border border-gray-100 p-4 hover:border-blue-200 hover:shadow-md transition-all group"
          >
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <span class="text-xs font-mono font-bold text-gray-400">{t.codigo}</span>
                  <StatusBadge estado={t.estado} />
                  <span class="text-xs text-gray-400 capitalize">{t.categoria}</span>
                </div>
                <h3 class="text-sm font-semibold text-gray-800 truncate group-hover:text-blue-700 transition-colors">
                  {t.titulo}
                </h3>
                <p class="text-xs text-gray-400 mt-1">
                  {new Date(t.fecha_creacion).toLocaleString('es-CO', { timeZone: 'America/Bogota', dateStyle: 'short', timeStyle: 'short' })}
                </p>
              </div>
              <i class="fas fa-chevron-right text-gray-300 group-hover:text-blue-500 text-xs mt-1 transition-colors shrink-0"></i>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</MesaAyudaLayout>
