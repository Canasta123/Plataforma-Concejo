---
import FormatosLayout from '../../layouts/FormatosLayout.astro';
import ExplorerCard from '../../components/ExplorerCard.astro';
---

<FormatosLayout
  title="Formatos de Gestión Contractual"
  numero="06"
  tituloHeader="Formatos de Gestión Contractual"
  subtituloHeader="Gestión Jurídica y Contractual"
  tipo="apoyo"
  badge="Gestión de Apoyo"
  badgeIcon="fas fa-file-contract"
  rutaActual="/apoyo/juridica-formatos"
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 h-full overflow-y-auto custom-scroll pr-2 pb-8">
    
    <!-- Card: Contratación Directa -->
    <div class="h-[420px]">
      <ExplorerCard
        titulo="Contratación Directa"
        icono="fas fa-file-signature"
        rutaExplorador="Formatos/6. Gestión Jurídica y Contractual/Formatos Gestión Contractual/Contratación Directa"
        borderColor="blue"
        bgIcon="fas fa-hand-holding-usd"
      />
    </div>

    <!-- Card: Mínima Cuantía -->
    <div class="h-[420px]">
      <ExplorerCard
        titulo="Mínima Cuantía"
        icono="fas fa-search-dollar"
        rutaExplorador="Formatos/6. Gestión Jurídica y Contractual/Formatos Gestión Contractual/Minima Cuantía"
        borderColor="gold"
        bgIcon="fas fa-coins"
      />
    </div>

    <!-- Card: Ejecución Contractual -->
    <div class="h-[420px]">
      <ExplorerCard
        titulo="Ejecución Contractual"
        icono="fas fa-cogs"
        rutaExplorador="Formatos/6. Gestión Jurídica y Contractual/Formatos Gestión Contractual/Ejecución Contractual"
        borderColor="blue"
      />
    </div>

    <!-- Card: Manuales y Resoluciones -->
    <div class="h-[420px]">
      <ExplorerCard
        titulo="Manuales y Resoluciones"
        icono="fas fa-book"
        rutaExplorador="Formatos/6. Gestión Jurídica y Contractual/Formatos Gestión Contractual/Manuales y Resoluciones"
        borderColor="gold"
        bgIcon="fas fa-gavel"
      />
    </div>

  </div>
</FormatosLayout>

<style>
  .custom-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scroll::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  .custom-scroll::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>


