---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
---

<ProcesoLayout
  title="Procedimientos TH - Apoyo"
  numero="08"
  tituloHeader="Procedimientos: Talento Humano"
  subtituloHeader="Gestión Administrativa, Financiera y Talento Humano"
  tipo="apoyo"
  badge="7 Procedimientos"
  badgeIcon="fas fa-users"
  rutaActual="/apoyo/administrativa-rrhh"
>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 h-full">

    <!-- Card 1 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-4 px-6 pb-6 border-t-4 border-brand-gold animate-on-scroll">
      <div class="flex justify-center mb-4">
        <a href="/C-Procedimientos/PROCED. ADMINISTRACIÓN, CUSTODIA Y ACTUALIZACION HISTORIAS LABORALES.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm border border-yellow-100 hover:bg-brand-gold hover:text-white transition-colors duration-300 group">
          <i class="fas fa-folder-open text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Historias Laborales
      </h3>
      <div class="flex-1 space-y-4 flex flex-col justify-between">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-bullseye text-brand-gold mr-1"></i> Objetivo</p>
          <p class="text-xs text-gray-700 leading-snug">Administración, custodia y actualización de historias laborales con confidencialidad.</p>
        </div>
        <div class="border-l-2 border-brand-gold pl-3 py-1">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-route text-brand-blue mr-1"></i> Alcance</p>
          <p class="text-xs text-gray-600 leading-snug">Desde vinculación hasta traslado al Archivo Central.</p>
        </div>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-4 px-6 pb-6 border-t-4 border-brand-gold animate-on-scroll" style="animation-delay: 0.1s;">
      <div class="flex justify-center mb-4">
        <a href="/C-Procedimientos/PROCEDIMIENTO DE INDUCCIÓN Y REINDUCCIÓN.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm border border-yellow-100 hover:bg-brand-gold hover:text-white transition-colors duration-300 group">
          <i class="fas fa-chalkboard-teacher text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Inducción y Reinducción
      </h3>
      <div class="flex-1 space-y-4 flex flex-col justify-between">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-bullseye text-brand-gold mr-1"></i> Objetivo</p>
          <p class="text-xs text-gray-700 leading-snug">Fortalecer competencias mediante inducción grupal o en puesto de trabajo.</p>
        </div>
        <div class="border-l-2 border-brand-gold pl-3 py-1">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-route text-brand-blue mr-1"></i> Alcance</p>
          <p class="text-xs text-gray-600 leading-snug">Desde ingreso de nuevos colaboradores hasta jornadas de reinducción.</p>
        </div>
      </div>
    </div>

    <!-- Card 3 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-4 px-6 pb-6 border-t-4 border-brand-gold animate-on-scroll" style="animation-delay: 0.2s;">
      <div class="flex justify-center mb-4">
        <a href="/C-Procedimientos/PROCEDIMIENTO EVALUACIÓN DE DESEMPEÑO.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm border border-yellow-100 hover:bg-brand-gold hover:text-white transition-colors duration-300 group">
          <i class="fas fa-clipboard-check text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Evaluación Desempeño
      </h3>
      <div class="flex-1 space-y-4 flex flex-col justify-between">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-bullseye text-brand-gold mr-1"></i> Objetivo</p>
          <p class="text-xs text-gray-700 leading-snug">Evaluar desempeño laboral según lineamientos CNSC.</p>
        </div>
        <div class="border-l-2 border-brand-gold pl-3 py-1">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-route text-brand-blue mr-1"></i> Alcance</p>
          <p class="text-xs text-gray-600 leading-snug">Desde concertación de compromisos hasta evaluación anual definitiva.</p>
        </div>
      </div>
    </div>

    <!-- Card 4 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-4 px-6 pb-6 border-t-4 border-brand-gold animate-on-scroll" style="animation-delay: 0.3s;">
      <div class="flex justify-center mb-4">
        <a href="/C-Procedimientos/PROCEDIMIENTO GENERACIÓN DE NOMINA.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm border border-yellow-100 hover:bg-brand-gold hover:text-white transition-colors duration-300 group">
          <i class="fas fa-file-invoice-dollar text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Generación de Nómina
      </h3>
      <div class="flex-1 space-y-4 flex flex-col justify-between">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-bullseye text-brand-gold mr-1"></i> Objetivo</p>
          <p class="text-xs text-gray-700 leading-snug">Generar liquidación mensual de nómina considerando novedades.</p>
        </div>
        <div class="border-l-2 border-brand-gold pl-3 py-1">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-route text-brand-blue mr-1"></i> Alcance</p>
          <p class="text-xs text-gray-600 leading-snug">Desde reporte de novedades hasta constancia de pagos.</p>
        </div>
      </div>
    </div>

    <!-- Card 5 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-4 px-6 pb-6 border-t-4 border-brand-gold animate-on-scroll" style="animation-delay: 0.4s;">
      <div class="flex justify-center mb-4">
        <a href="/C-Procedimientos/PROCEDIMIENTO PARA EL RECONOCIMIENTO Y LIQUIDACIÓN DE HORAS EXTRAS, DOMINICALES, (1).pdf" download target="_blank" class="w-16 h-16 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm border border-yellow-100 hover:bg-brand-gold hover:text-white transition-colors duration-300 group">
          <i class="fas fa-clock text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Reconocimiento Horas
      </h3>
      <div class="flex-1 space-y-4 flex flex-col justify-between">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-bullseye text-brand-gold mr-1"></i> Objetivo</p>
          <p class="text-xs text-gray-700 leading-snug">Revisar y aprobar horas extras, dominicales y recargos.</p>
        </div>
        <div class="border-l-2 border-brand-gold pl-3 py-1">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-route text-brand-blue mr-1"></i> Alcance</p>
          <p class="text-xs text-gray-600 leading-snug">Desde solicitud hasta notificación al servidor.</p>
        </div>
      </div>
    </div>

    <!-- Card 6 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-4 px-6 pb-6 border-t-4 border-brand-gold animate-on-scroll" style="animation-delay: 0.5s;">
      <div class="flex justify-center mb-4">
        <a href="/C-Procedimientos/PROCEDIMIENTO PRESTACIONES SOCIALES.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm border border-yellow-100 hover:bg-brand-gold hover:text-white transition-colors duration-300 group">
          <i class="fas fa-hand-holding-usd text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Prestaciones Sociales
      </h3>
      <div class="flex-1 space-y-4 flex flex-col justify-between">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-bullseye text-brand-gold mr-1"></i> Objetivo</p>
          <p class="text-xs text-gray-700 leading-snug">Reconocer y liquidar prestaciones sociales.</p>
        </div>
        <div class="border-l-2 border-brand-gold pl-3 py-1">
          <p class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-wider"><i class="fas fa-route text-brand-blue mr-1"></i> Alcance</p>
          <p class="text-xs text-gray-600 leading-snug">Desde radicación de solicitud hasta acto administrativo.</p>
        </div>
      </div>
    </div>

    <!-- Card 7 (Col Span 2) -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-4 px-6 pb-6 border-t-4 border-brand-gold col-span-1 lg:col-span-2 animate-on-scroll" style="animation-delay: 0.6s;">
      <div class="flex justify-center mb-4">
        <a href="/C-Procedimientos/PROCEDIMIENTO SITUACIONES ADMINISTRATIVAS.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm border border-yellow-100 hover:bg-brand-gold hover:text-white transition-colors duration-300 group">
          <i class="fas fa-user-cog text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Situaciones Administrativas
      </h3>
      <div class="flex-1 space-y-4 flex flex-col justify-between">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 h-full">
          <div class="bg-gray-50 p-4 rounded-lg border border-gray-100 h-full">
            <p class="text-[10px] text-gray-500 uppercase font-bold mb-2 tracking-wider"><i class="fas fa-bullseye text-brand-gold mr-1"></i> Objetivo</p>
            <p class="text-sm text-gray-700 leading-relaxed">Tramitar licencias, permisos, traslados, nombramientos y certificaciones.</p>
          </div>
          <div class="border-l-2 border-brand-gold pl-4 py-2 flex flex-col justify-center h-full">
            <p class="text-[10px] text-gray-500 uppercase font-bold mb-2 tracking-wider"><i class="fas fa-route text-brand-blue mr-1"></i> Alcance</p>
            <p class="text-sm text-gray-600 leading-relaxed">Desde identificación de la solicitud hasta documento administrativo final.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</ProcesoLayout>
