---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
import DownloadButton from '../../components/DownloadButton.astro';
---

<ProcesoLayout
  title="Elaboración y Supervisión de Contratos"
  numero="06"
  tituloHeader="Elaboración y Supervisión de Contratos"
  subtituloHeader="Procedimiento"
  tipo="apoyo"
  badge="Gestión Jurídica y Contractual"
  badgeIcon="fas fa-scale-balanced"
  rutaActual="/apoyo/juridica-contratos"
>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    
    <!-- COLUMNA IZQUIERDA (4/12) -->
    <div class="lg:col-span-4 flex flex-col gap-6">
      <!-- OBJETIVO -->
      <div class="bg-white rounded-xl p-6 card-shadow border-l-8 border-orange-400 animate-on-scroll">
        <h3 class="flex items-center gap-2 text-orange-500 font-bold text-sm uppercase tracking-wider mb-3">
          <i class="fas fa-bullseye text-brand-gold"></i> Objetivo
        </h3>
        <p class="text-sm text-gray-700 leading-relaxed text-justify">
          Establecer las directrices para la elaboración de contratos para la adquisición de bienes y/o servicios necesarios en el Concejo Municipal de Chía.
        </p>
      </div>

      <!-- RESPONSABLES -->
      <div class="bg-white rounded-xl p-6 card-shadow border-l-8 border-gray-300 animate-on-scroll" style="animation-delay: 0.1s;">
        <h3 class="flex items-center gap-2 text-brand-blue font-bold text-sm uppercase tracking-wider mb-5">
          <i class="fas fa-users text-brand-gold"></i> Responsables
        </h3>
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-orange-50 flex items-center justify-center text-orange-500">
              <i class="fas fa-scale-balanced"></i>
            </div>
            <div>
              <p class="font-bold text-gray-800 leading-tight">Gestión Jurídica y Contratación</p>
              <p class="text-xs text-gray-500 uppercase">Líder de Contratación</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMNA DERECHA (8/12) -->
    <div class="lg:col-span-8 flex flex-col gap-6">
      <!-- FLUJO -->
      <div class="bg-white rounded-xl p-6 card-shadow h-full flex flex-col animate-on-scroll" style="animation-delay: 0.2s;">
        <h3 class="flex items-center gap-2 text-brand-blue text-lg font-bold mb-6 border-b border-gray-100 pb-4">
          <i class="fas fa-diagram-project text-brand-gold"></i> Flujo del Procedimiento
        </h3>
        
        <div class="flex-1 overflow-y-auto pr-4 space-y-0 relative custom-scroll" style="max-height: 520px;">
          <!-- Timeline Line -->
          <div class="absolute left-[27px] top-4 bottom-4 w-1 bg-gray-200 rounded-full"></div>
          
          <!-- Steps -->
          {[
            { icon: 'fas fa-lightbulb', title: 'Identificación de la necesidad', desc: 'Se identifica la necesidad de contratar bienes o servicios para el funcionamiento institucional.', color: 'text-yellow-600' },
            { icon: 'fas fa-file-alt', title: 'Elaboración de estudios previos', desc: 'Definición de objeto contractual, justificación, presupuesto y condiciones del contrato.', color: 'text-blue-600' },
            { icon: 'fas fa-coins', title: 'Disponibilidad presupuestal', desc: 'Se verifica y expide el certificado de disponibilidad presupuestal.', color: 'text-green-600' },
            { icon: 'fas fa-file-signature', title: 'Elaboración del contrato', desc: 'Redacción del contrato conforme a la normatividad.', color: 'text-purple-600' },
            { icon: 'fas fa-pen-nib', title: 'Firma del contrato', desc: 'Suscripción del contrato entre las partes.', color: 'text-orange-600' },
            { icon: 'fas fa-user-check', title: 'Supervisión del contrato', desc: 'Seguimiento al cumplimiento de obligaciones contractuales.', color: 'text-indigo-600' },
            { icon: 'fas fa-clipboard-check', title: 'Informe de ejecución', desc: 'El supervisor documenta cumplimiento contractual.', color: 'text-teal-600' },
            { icon: 'fas fa-box-archive', title: 'Liquidación y cierre', desc: 'Liquidación del contrato y cierre del expediente.', color: 'text-gray-600' },
          ].map((step, i) => (
            <div class="relative pl-16 py-4 group">
              <div class={`absolute left-[13px] top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white border-4 border-gray-200 flex items-center justify-center z-10 group-hover:border-orange-500 transition-colors duration-300`}></div>
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 hover:shadow-md hover:border-gray-300 transition-all duration-300 flex items-start gap-4 ml-4">
                <div class={`w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center shrink-0 ${step.color}`}>
                  <i class={`${step.icon} text-xl`}></i>
                </div>
                <div>
                  <h4 class="font-bold text-gray-800 text-base mb-1">{step.title}</h4>
                  <p class="text-sm text-gray-600 leading-snug">{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 flex justify-end">
    <DownloadButton href="/C-Procedimientos/PROCEDIMIENTO ELABORACION Y SUPERVICIÓN DE CONTRATOS.pdf" tipo="apoyo" texto="Descargar Procedimiento" />
  </div>
</ProcesoLayout>

<style>
  .custom-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scroll::-webkit-scrollbar-track {
    background: #f1f5f9;
    border-radius: 10px;
  }
  .custom-scroll::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  .custom-scroll::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>
