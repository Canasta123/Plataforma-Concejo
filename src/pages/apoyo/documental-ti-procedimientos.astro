---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
import FileExplorer from '../../components/interactive/FileExplorer.svelte';
---

<ProcesoLayout
  title="Procedimientos - Gestión Documental y TI"
  numero="07"
  tituloHeader="Procedimientos y Formatos"
  subtituloHeader="Gestión Documental y TI"
  tipo="apoyo"
  badge="Ley General de Archivo"
  badgeIcon="fas fa-archive"
  rutaActual="/apoyo/documental-ti-procedimientos"
>
  <div class="flex flex-col gap-6">
    
    <!-- Card Superior: Actualización de TRD -->
    <div class="bg-white rounded-xl card-shadow p-6 flex flex-col border-t-4 border-brand-blue shrink-0 animate-on-scroll">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue shadow-sm">
          <i class="fas fa-table text-xl"></i>
        </div>
        <h3 class="font-bold text-brand-blue text-xl">Actualización de TRD</h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-100">
          <span class="text-xs font-bold text-gray-500 uppercase border-b border-gray-200 pb-2 block mb-3">Instrumentos Clave</span>
          <div class="space-y-3">
            <p class="text-sm text-gray-700 flex items-center gap-3">
              <i class="fas fa-certificate text-brand-gold w-4 text-center"></i> 
              <span class="font-medium">Certificado TRD</span>
            </p>
            <p class="text-sm text-gray-700 flex items-center gap-3">
              <i class="fas fa-project-diagram text-brand-gold w-4 text-center"></i> 
              <span class="font-medium">Cuadro Clasificación Documental (CCD)</span>
            </p>
            <p class="text-sm text-gray-700 flex items-center gap-3">
              <i class="fas fa-list-alt text-brand-gold w-4 text-center"></i> 
              <span class="font-medium">Tabla de Retención Documental (TRD)</span>
            </p>
          </div>
        </div>
        
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-100">
          <span class="text-xs font-bold text-gray-500 uppercase border-b border-gray-200 pb-2 block mb-3">Gestión del Cambio</span>
          <div class="space-y-3">
            <p class="text-sm text-gray-700 flex items-center gap-3">
              <i class="fas fa-file-pen text-brand-gold w-4 text-center"></i> 
              <span class="font-medium">Solicitud Creación, Actualización y Anulación</span>
            </p>
            <p class="text-sm text-gray-700 flex items-center gap-3">
              <i class="fas fa-rotate text-brand-gold w-4 text-center"></i> 
              <span class="font-medium">Procedimiento Actualización TRD</span>
            </p>
          </div>
        </div>
      </div>
      <p class="text-xs text-gray-400 italic mt-4 border-t border-gray-100 pt-3">
        <i class="fas fa-info-circle mr-1 text-brand-blue"></i> Manual de actualización TRD disponible próximamente.
      </p>
    </div>

    <!-- Card Inferior: Formatos Gestión Documental (con gestor) -->
    <div class="bg-white rounded-xl card-shadow p-6 flex flex-col border-t-4 border-brand-gold flex-1 animate-on-scroll min-h-[300px]" style="animation-delay: 0.1s;">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm">
          <i class="fas fa-folder-open text-xl"></i>
        </div>
        <h3 class="font-bold text-brand-blue text-xl">Formatos Gestión Documental</h3>
      </div>
      <div class="explorador-contenido relative z-10 h-[350px] overflow-y-auto custom-scroll pr-2">
      <FileExplorer client:load rutaBase="Formatos/7. Gestión Documental y Tecnologías de la Información/Gestión Documental" />
    </div>
    </div>
    
  </div>
</ProcesoLayout>

<style>
  .custom-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scroll::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  .custom-scroll::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>
