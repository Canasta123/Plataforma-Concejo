---
import FormatosLayout from '../../layouts/FormatosLayout.astro';
import ExplorerCard from '../../components/ExplorerCard.astro';
import InfoModal from '../../components/InfoModal.astro';
---

<FormatosLayout
  title="Formatos - Documental y TI"
  numero="07"
  tituloHeader="Formatos e Instrumentos"
  subtituloHeader="Gestión Documental y Tecnologías de la Información"
  tipo="apoyo"
  badge="Infraestructura y Datos"
  badgeIcon="fas fa-network-wired"
  rutaActual="/apoyo/documental-ti-formatos"
>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 h-full overflow-y-auto custom-scroll pr-2 pb-8 pt-4">
    
    <!-- Card 1: Gestión Operativa TI -->
    <div class="bg-white rounded-xl card-shadow p-6 relative border-t-4 border-brand-blue flex flex-col animate-on-scroll">
      <div class="absolute -top-3 -right-3 w-6 h-6 rounded-full bg-brand-gold text-white font-bold flex items-center justify-center text-xs shadow-md z-10">1</div>
      
      <div class="flex items-start gap-4 mb-6">
        <div class="w-12 h-12 rounded-full bg-blue-50 text-brand-blue flex items-center justify-center text-xl shrink-0">
          <i class="fas fa-cogs"></i>
        </div>
        <div>
          <span class="inline-block px-2 py-1 bg-blue-50 text-blue-700 text-[10px] font-bold uppercase tracking-wider rounded-md border border-blue-100 mb-1">Procedimientos</span>
          <h3 class="text-xl font-bold text-gray-800">Gestión Operativa TI</h3>
        </div>
      </div>
      
      <div class="grid grid-cols-3 gap-3 flex-1 items-center">
        <!-- Backup -->
        <button onclick="document.getElementById('backupModal').classList.remove('hidden'); document.getElementById('backupModal').classList.add('flex');" class="bg-blue-50 rounded-xl p-3 flex flex-col items-center justify-center text-center gap-1 border border-blue-100 transition-all duration-300 hover:shadow-[0_0_15px_rgba(51,89,164,0.3)] hover:-translate-y-1 hover:border-brand-blue hover:bg-blue-100 group w-full">
          <div class="w-10 h-10 flex items-center justify-center rounded-full bg-white shadow-sm mb-1 text-brand-blue group-hover:bg-brand-blue group-hover:text-white transition-colors">
            <i class="fas fa-database text-lg"></i>
          </div>
          <div>
            <h4 class="font-bold text-xs text-brand-blue">Backup</h4>
            <p class="text-[9px] text-gray-500">Copias de seguridad</p>
          </div>
        </button>
        <!-- Usuarios -->
        <button onclick="document.getElementById('usuariosModal').classList.remove('hidden'); document.getElementById('usuariosModal').classList.add('flex');" class="bg-blue-50 rounded-xl p-3 flex flex-col items-center justify-center text-center gap-1 border border-blue-100 transition-all duration-300 hover:shadow-[0_0_15px_rgba(51,89,164,0.3)] hover:-translate-y-1 hover:border-brand-blue hover:bg-blue-100 group w-full">
          <div class="w-10 h-10 flex items-center justify-center rounded-full bg-white shadow-sm mb-1 text-brand-blue group-hover:bg-brand-blue group-hover:text-white transition-colors">
            <i class="fas fa-user-cog text-lg"></i>
          </div>
          <div>
            <h4 class="font-bold text-xs text-brand-blue">Usuarios</h4>
            <p class="text-[9px] text-gray-500">Gestión de accesos</p>
          </div>
        </button>
        <!-- Mesa de Ayuda -->
        <button onclick="document.getElementById('mesaModal').classList.remove('hidden'); document.getElementById('mesaModal').classList.add('flex');" class="bg-blue-50 rounded-xl p-3 flex flex-col items-center justify-center text-center gap-1 border border-blue-100 transition-all duration-300 hover:shadow-[0_0_15px_rgba(51,89,164,0.3)] hover:-translate-y-1 hover:border-brand-blue hover:bg-blue-100 group w-full">
          <div class="w-10 h-10 flex items-center justify-center rounded-full bg-white shadow-sm mb-1 text-brand-blue group-hover:bg-brand-blue group-hover:text-white transition-colors">
            <i class="fas fa-headset text-lg"></i>
          </div>
          <div>
            <h4 class="font-bold text-xs text-brand-blue">Mesa de Ayuda</h4>
            <p class="text-[9px] text-gray-500">Soporte técnico</p>
          </div>
        </button>
      </div>
    </div>

    <!-- Card 2: Registros y Control -->
    <div class="bg-white rounded-xl card-shadow p-6 relative border-t-4 border-brand-blue flex flex-col animate-on-scroll" style="animation-delay: 0.1s;">
      <div class="absolute -top-3 -right-3 w-6 h-6 rounded-full bg-brand-gold text-white font-bold flex items-center justify-center text-xs shadow-md z-10">2</div>
      
      <div class="flex items-start gap-4 mb-4">
        <div class="w-12 h-12 rounded-full bg-blue-50 text-brand-blue flex items-center justify-center text-xl shrink-0">
          <i class="fas fa-file-alt"></i>
        </div>
        <div>
          <span class="inline-block px-2 py-1 bg-yellow-50 text-yellow-700 text-[10px] font-bold uppercase tracking-wider rounded-md border border-yellow-100 mb-1">Formatos</span>
          <h3 class="text-xl font-bold text-gray-800">Registros y Control</h3>
        </div>
      </div>
      
      <div class="flex flex-col gap-2 flex-1">
        <a href="/Formatos DEC/Formato_backup.docx" download class="flex items-center justify-between p-2 rounded-lg bg-blue-50 border border-blue-100 hover:border-brand-blue transition-colors group">
          <div class="flex items-center gap-3">
            <i class="fas fa-file-word text-blue-600"></i>
            <div>
              <p class="text-[11px] font-bold text-gray-700 group-hover:text-brand-blue truncate max-w-[200px] sm:max-w-[300px]">Formato backup.docx</p>
              <p class="text-[10px] text-gray-500">54.02 KB</p>
            </div>
          </div>
          <i class="fas fa-download text-gray-400 group-hover:text-brand-blue"></i>
        </a>
        
        <a href="/Formatos DEC/INVENTARIO_ACTIVOS.xlsx" download class="flex items-center justify-between p-2 rounded-lg bg-green-50 border border-green-200 hover:border-green-500 transition-colors group">
          <div class="flex items-center gap-3">
            <i class="fas fa-file-excel text-green-600"></i>
            <div>
              <p class="text-[11px] font-bold text-gray-700 group-hover:text-green-700 truncate max-w-[200px] sm:max-w-[300px]">FORMATO INVENTARIO DE ACTIVOS DE INFORMACIÓN DATOS.xlsx</p>
              <p class="text-[10px] text-gray-500">31.29 KB</p>
            </div>
          </div>
          <i class="fas fa-download text-gray-400 group-hover:text-green-600"></i>
        </a>

        <a href="/Formatos DEC/formato_mantenimientos.docx" download class="flex items-center justify-between p-2 rounded-lg bg-blue-50 border border-blue-100 hover:border-brand-blue transition-colors group">
          <div class="flex items-center gap-3">
            <i class="fas fa-file-word text-blue-600"></i>
            <div>
              <p class="text-[11px] font-bold text-gray-700 group-hover:text-brand-blue truncate max-w-[200px] sm:max-w-[300px]">formato mantenimientos PC.docx</p>
              <p class="text-[10px] text-gray-500">55.53 KB</p>
            </div>
          </div>
          <i class="fas fa-download text-gray-400 group-hover:text-brand-blue"></i>
        </a>

        <a href="/Formatos DEC/PLANILLA_SESIONES.xlsx" download class="flex items-center justify-between p-2 rounded-lg bg-green-50 border border-green-200 hover:border-green-500 transition-colors group">
          <div class="flex items-center gap-3">
            <i class="fas fa-file-excel text-green-600"></i>
            <div>
              <p class="text-[11px] font-bold text-gray-700 group-hover:text-green-700 truncate max-w-[200px] sm:max-w-[300px]">PLANILLA APOYO SESIONES.xlsx</p>
              <p class="text-[10px] text-gray-500">28.05 KB</p>
            </div>
          </div>
          <i class="fas fa-download text-gray-400 group-hover:text-green-600"></i>
        </a>

        <a href="/Formatos DEC/PLANILLA_APOYOS.xlsx" download class="flex items-center justify-between p-2 rounded-lg bg-green-50 border border-green-200 hover:border-green-500 transition-colors group">
          <div class="flex items-center gap-3">
            <i class="fas fa-file-excel text-green-600"></i>
            <div>
              <p class="text-[11px] font-bold text-gray-700 group-hover:text-green-700 truncate max-w-[200px] sm:max-w-[300px]">PLANILLA APOYOS TECNOLOGICOS.xlsx</p>
              <p class="text-[10px] text-gray-500">27.89 KB</p>
            </div>
          </div>
          <i class="fas fa-download text-gray-400 group-hover:text-green-600"></i>
        </a>

        <a href="/Formatos DEC/solicitud_usuarios.docx" download class="flex items-center justify-between p-2 rounded-lg bg-blue-50 border border-blue-100 hover:border-brand-blue transition-colors group">
          <div class="flex items-center gap-3">
            <i class="fas fa-file-word text-blue-600"></i>
            <div>
              <p class="text-[11px] font-bold text-gray-700 group-hover:text-brand-blue truncate max-w-[200px] sm:max-w-[300px]">solicitud de usuarios.docx</p>
              <p class="text-[10px] text-gray-500">386.05 KB</p>
            </div>
          </div>
          <i class="fas fa-download text-gray-400 group-hover:text-brand-blue"></i>
        </a>
      </div>
    </div>

    <!-- Card 3: Planes Estratégicos -->
    <div class="bg-white rounded-xl card-shadow p-6 relative border-t-4 border-brand-blue flex flex-col animate-on-scroll" style="animation-delay: 0.2s;">
      <div class="absolute -top-3 -right-3 w-6 h-6 rounded-full bg-brand-gold text-white font-bold flex items-center justify-center text-xs shadow-md z-10">3</div>
      
      <div class="flex items-start gap-4 mb-6">
        <div class="w-12 h-12 rounded-full bg-blue-50 text-brand-blue flex items-center justify-center text-xl shrink-0">
          <i class="fas fa-chart-line"></i>
        </div>
        <div>
          <span class="inline-block px-2 py-1 bg-blue-50 text-blue-700 text-[10px] font-bold uppercase tracking-wider rounded-md border border-blue-100 mb-1">Seguimiento</span>
          <h3 class="text-xl font-bold text-gray-800">Planes Estratégicos</h3>
        </div>
      </div>
      
      <div class="flex flex-col gap-4">
        <div class="flex items-start gap-3">
          <i class="fas fa-medal text-brand-gold mt-0.5"></i>
          <p class="text-xs text-gray-600 leading-snug"><span class="font-bold text-gray-800">PETI:</span> Primer seguimiento al Plan Estratégico de Tecnologías de la Información.</p>
        </div>
        <div class="flex items-start gap-3">
          <i class="fas fa-user-shield text-brand-gold mt-0.5"></i>
          <p class="text-xs text-gray-600 leading-snug"><span class="font-bold text-gray-800">Seguridad y Privacidad:</span> Seguimiento al Plan de Seguridad y Privacidad de la Información.</p>
        </div>
        <div class="flex items-start gap-3">
          <i class="fas fa-exclamation-triangle text-brand-gold mt-0.5"></i>
          <p class="text-xs text-gray-600 leading-snug"><span class="font-bold text-gray-800">Riesgos:</span> Seguimiento al Plan de Tratamiento de Riesgos de Seguridad.</p>
        </div>
      </div>
    </div>

    <!-- Card 4: Normatividad TI -->
    <div class="bg-white rounded-xl card-shadow p-6 relative border-t-4 border-brand-blue flex flex-col animate-on-scroll" style="animation-delay: 0.3s;">
      <div class="absolute -top-3 -right-3 w-6 h-6 rounded-full bg-brand-gold text-white font-bold flex items-center justify-center text-xs shadow-md z-10">4</div>
      
      <div class="flex items-start gap-4 mb-6">
        <div class="w-12 h-12 rounded-full bg-blue-50 text-brand-blue flex items-center justify-center text-xl shrink-0">
          <i class="fas fa-balance-scale"></i>
        </div>
        <div>
          <span class="inline-block px-2 py-1 bg-yellow-50 text-yellow-700 text-[10px] font-bold uppercase tracking-wider rounded-md border border-yellow-100 mb-1">Políticas</span>
          <h3 class="text-xl font-bold text-gray-800">Normatividad TI</h3>
        </div>
      </div>
      
      <div class="flex flex-col gap-4">
        <div class="flex items-start gap-3">
          <i class="fas fa-leaf text-brand-gold mt-0.5"></i>
          <p class="text-xs text-gray-600 leading-snug"><span class="font-bold text-gray-800">Política de Cero Papel:</span> Folletos y estrategias de reducción de consumo.</p>
        </div>
        <div class="flex items-start gap-3">
          <i class="fas fa-lock text-brand-gold mt-0.5"></i>
          <p class="text-xs text-gray-600 leading-snug"><span class="font-bold text-gray-800">Privacidad y Seguridad:</span> Política de seguridad de la información institucional.</p>
        </div>
        <div class="flex items-start gap-3">
          <i class="fas fa-address-card text-brand-gold mt-0.5"></i>
          <p class="text-xs text-gray-600 leading-snug"><span class="font-bold text-gray-800">Datos Personales:</span> Política de tratamiento y protección de datos personales.</p>
        </div>
      </div>
    </div>

    <!-- Modals -->
    <InfoModal
      id="backupModal"
      title="Backup / Copias de Seguridad"
      icon="fas fa-database"
      description="Procedimiento encargado de garantizar la protección de la información institucional mediante la creación de copias de seguridad periódicas de servidores, bases de datos y sistemas críticos."
      listItems={['Programación automática de respaldos', 'Verificación de integridad', 'Almacenamiento seguro', 'Restauración de información']}
      downloadUrl="/C-Procedimientos/PROCEDIMIENTO BACKUP.pdf"
    />

    <InfoModal
      id="usuariosModal"
      title="Creación de Usuarios"
      icon="fas fa-user-cog"
      description="Gestión de creación, modificación y eliminación de cuentas institucionales para garantizar control de accesos y seguridad de la información."
      listItems={['Solicitud del funcionario', 'Validación del responsable', 'Asignación de permisos', 'Registro en inventario']}
      downloadUrl="/C-Procedimientos/PROCEDIEMTOS USUARIOS.pdf"
    />

    <InfoModal
      id="mesaModal"
      title="Mesa de Ayuda"
      icon="fas fa-headset"
      description="Procedimiento para la atención de incidencias tecnológicas relacionadas con equipos, software y conectividad institucional."
      listItems={['Recepción del incidente', 'Registro de soporte', 'Diagnóstico técnico', 'Solución y cierre']}
      downloadUrl="/C-Procedimientos/PROCEDIMIENTO MESA DE AYUDA.pdf"
      actionUrl="/mesa-ayuda/login"
      actionText="Ir a la Mesa de Ayuda"
      actionIcon="fas fa-external-link-alt"
    />

  </div>
</FormatosLayout>

<style>
  .custom-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scroll::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  .custom-scroll::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>
