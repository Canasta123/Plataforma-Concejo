---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
import ManualesInteractivos from '../../components/interactive/ManualesInteractivos.svelte';
import FormatosList from '../../components/interactive/FormatosList.svelte';
---

<ProcesoLayout
  title="Gestión Documental - Procedimientos y Formatos"
  numero="07"
  tituloHeader="Gestión Documental"
  subtituloHeader="Procedimientos, Guías y Formatos"
  tipo="apoyo"
  badge="Ley General de Archivo"
  badgeIcon="fas fa-archive"
  rutaActual="/apoyo/documental-formatos"
>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
    <!-- Columna Izquierda (40% aprox.) -->
    <div class="col-span-12 lg:col-span-5 flex flex-col gap-6">
      
      <!-- Card Superior: Actualización de TRD -->
      <div class="bg-white rounded-xl card-shadow p-5 flex flex-col border-t-4 border-brand-blue shrink-0 animate-on-scroll">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue shadow-sm">
            <i class="fas fa-table text-lg"></i>
          </div>
          <h3 class="font-bold text-brand-blue text-base">Actualización de TRD</h3>
        </div>
        
        <p class="text-xs text-gray-500 leading-relaxed mb-4">
          Procedimiento oficial de actualización y control de las Tablas de Retención Documental para la gestión del cambio.
        </p>

        <div class="flex flex-col gap-2 bg-gray-50 rounded-lg p-3 border border-gray-100/50">
          <span class="text-[10px] font-bold text-gray-400 uppercase border-b border-gray-200/60 pb-1.5 block mb-1">Instrumentos y Trámites</span>
          <div class="grid grid-cols-1 gap-2">
            <div class="text-xs text-gray-700 flex items-center gap-2">
              <i class="fas fa-circle-check text-brand-gold text-[10px]"></i> 
              <span class="font-medium">Certificado de Aprobación TRD</span>
            </div>
            <div class="text-xs text-gray-700 flex items-center gap-2">
              <i class="fas fa-circle-check text-brand-gold text-[10px]"></i> 
              <span class="font-medium">Cuadro Clasificación (CCD)</span>
            </div>
            <div class="text-xs text-gray-700 flex items-center gap-2">
              <i class="fas fa-circle-check text-brand-gold text-[10px]"></i> 
              <span class="font-medium">Tablas de Retención (TRD)</span>
            </div>
            <div class="text-xs text-gray-700 flex items-center gap-2">
              <i class="fas fa-circle-check text-brand-gold text-[10px]"></i> 
              <span class="font-medium">Formato Solicitud de Cambio</span>
            </div>
          </div>
        </div>
        
        <!-- Botón de Descarga del Procedimiento -->
        <div class="mt-4 pt-3 border-t border-gray-100 flex justify-between items-center mt-auto">
          <span class="text-[10px] text-gray-400 italic">Procedimiento oficial de control</span>
          <a 
            href="/C-Procedimientos/Procedimiento Actualizacion TRD.pdf" 
            download 
            class="bg-brand-blue hover:bg-blue-700 text-white text-xs font-bold py-1.5 px-3 rounded shadow-sm transition-all flex items-center gap-1.5"
            title="Descargar Procedimiento de Actualización de TRD"
          >
            <i class="fas fa-download text-[10px]"></i>
            <span>Descargar PDF</span>
          </a>
        </div>
      </div>

      <!-- Card Inferior: Formatos Gestión Documental (Categorizados) -->
      <div class="bg-white rounded-xl card-shadow p-5 flex flex-col border-t-4 border-brand-gold flex-1 animate-on-scroll min-h-[400px]" style="animation-delay: 0.1s;">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-full bg-yellow-50 flex items-center justify-center text-brand-gold shadow-sm">
            <i class="fas fa-folder-open text-lg"></i>
          </div>
          <div>
            <h3 class="font-bold text-brand-blue text-base">Formatos del Proceso</h3>
            <p class="text-[10px] text-gray-500">Listado de plantillas oficiales para descarga</p>
          </div>
        </div>
        
        <div class="flex-1 mt-2">
          <FormatosList client:load />
        </div>
      </div>
      
    </div>

    <!-- Columna Derecha (60% aprox.) - Manuales Interactivos -->
    <div class="col-span-12 lg:col-span-7 flex flex-col animate-on-scroll" style="animation-delay: 0.2s;">
      <ManualesInteractivos client:load />
    </div>
  </div>
</ProcesoLayout>

<style>
  /* Scrollbar styles are handled locally in Svelte components */
</style>

