---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
---

<ProcesoLayout
  title="Procedimientos - Gestión de Calidad"
  numero="02"
  tituloHeader="Procedimientos del Sistema"
  subtituloHeader="Gestión de Calidad"
  tipo="estrategico"
  badge="ISO 9001:2015"
  badgeIcon="fas fa-check-circle"
  rutaActual="/estrategicos/calidad-procedimientos"
>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">
    
    <!-- Proc 1 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/Proc. Acciones Correctivas y plan de mejoramiento.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-tools text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Acciones Correctivas y Plan de Mejoramiento
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Dir. Administrativo y Financiero, Jefe Control Interno</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Identificar, analizar y eliminar causas de no conformidades para prevenir recurrencia.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600">Desde detección de NC hasta cierre de acciones o planes de mejoramiento.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Proc 2 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll" style="animation-delay: 0.1s;">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/Procedimiento Auditoria Interna de Calidad.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-clipboard-check text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Auditoría Interna de Calidad
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Director Administrativo y Financiero</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Evaluar cumplimiento de requisitos ISO 9001:2015 y eficacia del SGC.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600">Desde aprobación del Programa Anual hasta verificación de acciones correctivas.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Proc 3 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll" style="animation-delay: 0.2s;">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/Procedimiento Control Documentos SGC.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-file-contract text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Control de Documentos del SGC
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Dir. Administrativo, Responsables de Proceso</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Controlar documentos del SGC: elaboración, revisión, aprobación, publicación.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600">Desde identificación de necesidad documental hasta publicación y socialización.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Proc 4 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll" style="animation-delay: 0.3s;">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/Procedimiento información documentada.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-archive text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Control de Información Documentada
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Dir. Administrativo, Responsables de Proceso</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Controlar la difusión controlada y conservación de documentos del SGC.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600">Inicia con elaboración/identificación y finaliza con el archivo.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Proc 5 -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll" style="animation-delay: 0.4s;">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/Procedimiento Revisión por Dirección .pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-chart-line text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Revisión por la Dirección
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Alta Dirección, Mesa Directiva, Líderes</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Medir de manera eficaz y eficiente el desempeño del SGC.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600">Desde recopilación de información hasta seguimiento a resultados y acciones.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</ProcesoLayout>
