---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
import TimelineStep from '../../components/TimelineStep.astro';
import DownloadButton from '../../components/DownloadButton.astro';
---

<ProcesoLayout
  title="Direccionamiento Estratégico y Comunicaciones"
  numero="01"
  tituloHeader="Direccionamiento Estratégico y Comunicaciones"
  subtituloHeader="Caracterización del Proceso"
  tipo="estrategico"
  badge="Macroproceso Estratégico"
  badgeIcon="fas fa-sitemap"
  footerTexto="Versión 2026 | Sistema de Gestión de Calidad"
  rutaActual="/estrategicos/direccionamiento"
>
  <div class="grid grid-cols-12 gap-6 h-full">
    <div class="col-span-12 md:col-span-4 flex flex-col gap-6">

      <div class="bg-white rounded-xl p-6 card-shadow border-l-8 border-brand-blue relative overflow-hidden group animate-on-scroll">
        <div class="absolute right-0 top-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
          <i class="fas fa-chess-king text-8xl" style="color: #3359A4;"></i>
        </div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center" style="color: #3359A4;">
              <i class="fas fa-layer-group"></i>
            </div>
            <h3 class="text-gray-500 font-bold text-xs uppercase tracking-wider">Tipo de Proceso</h3>
          </div>
          <p class="text-2xl font-bold" style="color: #3359A4;">Estratégico</p>
          <div class="mt-4 text-sm text-gray-600 leading-snug">
            Procesos destinados a definir y controlar las metas de la organización, sus políticas y estrategias.
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl p-6 card-shadow border-l-8 border-gray-300 flex-1 animate-on-scroll">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-600">
            <i class="fas fa-user-tie"></i>
          </div>
          <h3 class="text-gray-500 font-bold text-xs uppercase tracking-wider">Responsables / Encargados</h3>
        </div>
        <div class="space-y-4">
          <div class="flex items-start gap-3 p-3 rounded-lg bg-gray-50 border border-gray-100">
            <div class="mt-1" style="color: #FFD402;"><i class="fas fa-gavel"></i></div>
            <div>
              <p class="font-bold text-gray-800 text-sm">Mesa Directiva</p>
              <p class="text-xs text-gray-500">Alta Dirección</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-gray-50 border border-gray-100">
            <div class="mt-1" style="color: #3359A4;"><i class="fas fa-bullhorn"></i></div>
            <div>
              <p class="font-bold text-gray-800 text-sm">Jefe Oficina Asesora</p>
              <p class="text-xs text-gray-500">Prensa y Comunicaciones</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="col-span-12 md:col-span-8 flex flex-col gap-6">

      <div class="bg-white rounded-xl p-8 card-shadow relative animate-on-scroll">
        <div class="absolute -top-3 left-8 text-white px-4 py-1 rounded shadow-sm text-xs font-bold uppercase tracking-widest border border-black" style="background-color: #FFD402; color: #1f2937;">
          <i class="fas fa-bullseye mr-2"></i>Objetivo del Proceso
        </div>
        <div class="mt-4 flex gap-6 items-start">
          <div class="flex-1">
            <p class="text-lg text-gray-700 leading-relaxed font-medium">
              Aprobar y hacer seguimiento a la ejecución del plan de acción de la Corporación, así como al funcionamiento administrativo de la misma acorde con la normatividad vigente.
            </p>
            <div class="mt-4 pt-4 border-t border-gray-100 flex items-center" style="color: #3359A4;">
              <i class="fas fa-check-circle mr-2" style="color: #FFD402;"></i>
              <p class="text-sm font-semibold">Garantizar que la comunidad y los grupos de interés participen y cuenten con información veraz y oportuna.</p>
            </div>
          </div>
          <div class="w-1/4 flex justify-center items-center opacity-20">
            <i class="fas fa-crosshairs text-6xl text-gray-400"></i>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl p-8 card-shadow flex-1 relative animate-on-scroll">
        <div class="absolute -top-3 left-8 text-white px-4 py-1 rounded shadow-sm text-xs font-bold uppercase tracking-widest border border-black" style="background-color: #3359A4;">
          <i class="fas fa-map-signs mr-2"></i>Alcance
        </div>
        <div class="mt-6 relative">
          <TimelineStep
            tipo="inicio"
            descripcion="Inicia con la <strong>formulación del plan de acción</strong> de la Corporación y demás instrumentos de planeación, así como su oportuna divulgación."
          />
          <TimelineStep
            tipo="fin"
            descripcion="Finaliza con el <strong>seguimiento y evaluación</strong> del Proceso."
          />
        </div>
      </div>

      <div class="flex justify-end animate-on-scroll">
        <DownloadButton href="/C-Procesos/DEC.pdf" tipo="estrategico" texto="Descargar Caracterización" />
      </div>

    </div>
  </div>
</ProcesoLayout>
