---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
---

<ProcesoLayout
  title="Comunicaciones - Direccionamiento Estratégico"
  numero="01"
  tituloHeader="Procedimientos: Comunicaciones"
  subtituloHeader="Direccionamiento Estratégico y Comunicaciones"
  tipo="estrategico"
  badge="3 Procedimientos"
  badgeIcon="fas fa-layer-group"
  rutaActual="/estrategicos/direccionamiento-comunicaciones"
>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">
    
    <!-- Card 1: Comunicación Convergente -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/1. PROCEDIMIENTO PARA LA COMUNICACION CONVERGENTE.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-network-wired text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Comunicación Convergente
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Jefe Oficina Asesora de Prensa y Comunicaciones</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Generar e implementar la estrategia de comunicación convergente en el Concejo Municipal de Chía, mediante lineamientos y metodologías claras.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Inicio:</span> Uso de página web y redes sociales.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-red-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Fin:</span> Actualización y manejo constante.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 2: Comunicación Interna y Externa -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll" style="animation-delay: 0.1s;">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/2. PROCEDIMIENTO PARA LA COMUNICACION INTERNA Y EXTERNA.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-comments text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Comunicación Interna y Externa
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Jefe Oficina Prensa, Apoyo Técnico Administrativo</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Comunicar información institucional de interés para funcionarios y ciudadanía a través de canales oficiales internos y externos.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Inicio:</span> Planificación de agenda.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-red-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Fin:</span> Difusión de información a partes interesadas.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 3: Información Página Web -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll" style="animation-delay: 0.2s;">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/3. PROCEDIMIENTO PUBLICACION  INFORMACION PAGINA WEB.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-laptop-code text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Publicación Página Web
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Jefe Oficina Prensa, Técnico Administrativo</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Establecer lineamientos y metodología para publicar información institucional en la Web oficial del Concejo.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Inicio:</span> Solicitud de publicación.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-red-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Fin:</span> Publicación efectiva en la web.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</ProcesoLayout>
