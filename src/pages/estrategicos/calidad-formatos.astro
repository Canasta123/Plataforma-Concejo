---
import FormatosLayout from '../../layouts/FormatosLayout.astro';
import ExplorerCard from '../../components/ExplorerCard.astro';

const comites = [
  { icon: 'fas fa-list-check', name: 'Comité de Gestión y Desempeño Institucional' },
  { icon: 'fas fa-shield-alt', name: 'Comité Institucional de Control Interno' },
  { icon: 'fas fa-file-signature', name: 'Comité de Contratación' },
  { icon: 'fas fa-handshake', name: 'Comité de Relacionamiento con el Ciudadano' },
  { icon: 'fas fa-coins', name: 'Comité Técnico de Sostenibilidad Contable' },
  { icon: 'fas fa-box-open', name: 'Comité Evaluador de Bajas' },
  { icon: 'fas fa-balance-scale', name: 'Comité de Conciliación y Defensa Judicial' },
  { icon: 'fas fa-hard-hat', name: 'Comité Paritario de SST (COPASST)' },
  { icon: 'fas fa-users', name: 'Comité de Convivencia Laboral' },
  { icon: 'fas fa-user-tie', name: 'Comisión de Personal' },
  { icon: 'fas fa-lightbulb', name: 'Comité de Innovación Tecnológica' },
];
---

<FormatosLayout
  title="Formatos y Comités - Gestión de Calidad"
  numero="02"
  tituloHeader="Formatos y Comités Institucionales"
  subtituloHeader="Gestión de Calidad"
  tipo="estrategico"
  badge="Estructura de Apoyo"
  badgeIcon="fas fa-users"
  rutaActual="/estrategicos/calidad-formatos"
>
  <div class="flex flex-col gap-8 h-full overflow-y-auto custom-scroll pr-2 pb-8">
    
    <!-- Explorer Card -->
    <div class="h-[300px] shrink-0">
      <ExplorerCard
        titulo="Formatos del Sistema de Gestión"
        icono="fas fa-file-alt"
        rutaExplorador="Formatos/2. Gestión de Calidad/Formatos del Sistema de Gestión"
        borderColor="gold"
        bgIcon="fas fa-folder-open"
      />
    </div>

    <!-- Comités Institucionales -->
    <div class="flex flex-col gap-4 animate-on-scroll">
      <div class="flex items-center gap-2 pb-2 border-b-2 border-gray-100">
        <i class="fas fa-users text-brand-gold"></i>
        <h3 class="text-lg font-bold text-brand-blue uppercase">Comités Institucionales</h3>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {comites.map((comite) => (
          <div class="bg-white rounded-lg card-shadow p-3 border-l-4 border-brand-blue flex items-center gap-3 hover:border-brand-gold transition-colors group cursor-pointer">
            <div class="w-8 h-8 rounded-full bg-blue-50 text-brand-blue flex items-center justify-center shrink-0 group-hover:bg-brand-gold group-hover:text-white transition-colors">
              <i class={`${comite.icon} text-sm`}></i>
            </div>
            <p class="text-[11px] font-bold text-gray-700 leading-tight group-hover:text-brand-blue transition-colors">
              {comite.name}
            </p>
          </div>
        ))}
        <!-- Caja Vacía Concejo -->
        <div class="bg-gray-50 border-2 border-dashed border-gray-200 rounded-lg p-3 flex items-center justify-center">
          <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest">Concejo Municipal 2026</p>
        </div>
      </div>
    </div>

    <!-- Instrumento de Seguimiento -->
    <a href="/Formatos DEC/Cronograma_Informes.pdf" target="_blank" class="bg-gradient-to-r from-[#1e3a8a] to-[#3359A4] rounded-xl p-5 card-shadow flex flex-col md:flex-row items-center justify-between gap-4 group hover:shadow-xl transition-all duration-300 animate-on-scroll" style="animation-delay: 0.1s;">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center text-white border border-white/20 group-hover:bg-brand-gold group-hover:border-brand-gold transition-colors shrink-0">
          <i class="fas fa-calendar-check text-xl"></i>
        </div>
        <div>
          <p class="text-[10px] font-bold text-gray-300 uppercase tracking-wider mb-1">Instrumento de Seguimiento</p>
          <h3 class="text-lg md:text-xl font-bold text-white leading-tight">Cronograma de Informes Concejo Municipal de Chía V2</h3>
        </div>
      </div>
      <div class="flex items-center gap-4 pl-4 md:border-l border-white/20 shrink-0">
        <div class="text-right hidden sm:block">
          <p class="text-sm font-bold text-white">Planificación Anual</p>
          <p class="text-[10px] text-blue-200 uppercase tracking-wide">Seguimiento y Control</p>
        </div>
        <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-brand-blue shadow-inner group-hover:scale-110 transition-transform">
          <i class="fas fa-clock text-lg"></i>
        </div>
      </div>
    </a>

  </div>
</FormatosLayout>

<style>
  .custom-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scroll::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  .custom-scroll::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>


