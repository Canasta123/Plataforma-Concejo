---
import ProcesoLayout from '../../layouts/ProcesoLayout.astro';
---

<ProcesoLayout
  title="Procedimientos - Direccionamiento Estratégico"
  numero="01"
  tituloHeader="Procedimientos: Direccionamiento Estratégico"
  subtituloHeader="Direccionamiento Estratégico y Comunicaciones"
  tipo="estrategico"
  badge="3 Procedimientos"
  badgeIcon="fas fa-layer-group"
  rutaActual="/estrategicos/direccionamiento-procedimientos"
>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">
    
    <!-- Card 1: Plan de Acción -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/PROCEDIMIENTO SEG EVAL PA-PI.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-tasks text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Seguimiento y Evaluación al Plan de Acción
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Mesa Directiva, Dirección Administrativa y Financiera</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Establecer lineamientos para elaboración, aprobación, ejecución y seguimiento de metas del plan de acción y planes institucionales (Dec 612/2018).
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Inicio:</span> Definición de actividades y metas.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-red-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Fin:</span> Seguimiento cuatrimestral al cumplimiento.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 2: Empalme -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll" style="animation-delay: 0.1s;">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/1. PROCEDIMIENTO EMPALME POR VIGENCIA.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-handshake text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Procedimiento de Empalme
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Mesa Directiva, Dirección Administrativa y Financiera</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Realizar un proceso efectivo y transparente de entrega y recibo formal al finalizar mandato, conforme a la Ley 951 de 2005.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Inicio:</span> Conformación equipo de empalme.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-red-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Fin:</span> Acto formal de entrega de informe de gestión.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 3: Rendición de Cuentas -->
    <div class="bg-white rounded-xl card-shadow flex flex-col relative pt-2 px-6 pb-6 animate-on-scroll" style="animation-delay: 0.2s;">
      <div class="flex justify-center mb-2">
        <a href="/C-Procedimientos/1. PROCEDIMIENTO AUDIENCIA PUBLICA.pdf" download target="_blank" class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center text-brand-blue hover:bg-brand-blue hover:text-white transition-colors duration-300 shadow-sm border border-blue-100 group">
          <i class="fas fa-bullhorn text-2xl group-hover:hidden"></i>
          <i class="fas fa-download text-2xl hidden group-hover:block"></i>
        </a>
      </div>
      <h3 class="text-center font-bold text-brand-blue text-lg leading-tight mb-4 min-h-[3rem] flex items-center justify-center">
        Rendición de Cuentas
      </h3>
      <div class="flex-1 space-y-4">
        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-user-tie text-brand-gold text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Encargado</p>
          </div>
          <p class="text-sm text-gray-800 font-medium leading-snug">Mesa Directiva, Dir. Administrativa, Jefe de Prensa</p>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-1">
            <i class="fas fa-bullseye text-brand-blue text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Objetivo</p>
          </div>
          <p class="text-sm text-gray-600 leading-snug text-justify">
            Dialogar y evaluar con ciudadanos sobre la gestión (semestre/año) para determinar cumplimiento misional y garantizar derechos.
          </p>
        </div>
        <div class="mt-auto">
          <div class="flex items-center gap-2 mb-2">
            <i class="fas fa-route text-green-600 text-xs"></i>
            <p class="text-xs font-bold text-gray-500 uppercase">Alcance</p>
          </div>
          <div class="relative border-l-2 border-green-200 pl-4 py-1 space-y-3">
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-green-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Inicio:</span> Definición del Plan Anual.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-red-500 border-2 border-white"></div>
              <p class="text-xs text-gray-600"><span class="font-bold text-gray-800">Fin:</span> Publicación resultados Audiencia Pública.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</ProcesoLayout>
